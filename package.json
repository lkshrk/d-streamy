{
  "name": "d-streamy",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "./scripts/build.sh",
    "build:swift": "swift build -c release",
    "build:daemon": "bun build src/daemon/index.ts --outfile .build/daemon.js --target node",
    "test": "bun test",
    "update": "bun update && swift package update",
    "outdated": "bun outdated && swift package show-dependencies"
  },
  "dependencies": {
    "@dank074/discord-video-stream": "^6.0.0",
    "@discordjs/opus": "^0.10.0",
"discord.js-selfbot-v13": "^3.6.0",
    "opusscript": "^0.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@lng2004/node-datachannel",
    "node-av"
  ]
}
